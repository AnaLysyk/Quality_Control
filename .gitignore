# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.npm-cache/

# Next.js build output
/.next/
/out/

# build & dist
/build
/dist

# coverage
/coverage

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Prisma generated
/generated/prisma

# env files (allow templates)
.env*
!.env.example
!.env.local.example

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS / editor
.DS_Store
*.pem

# local runtime artifacts
.dev.pid
__localstore_snapshot*
.tmp/
.tmp-tailwind*.css
.pytest_cache/

# Playwright artifacts
test-results/
playwright-report/
blob-report/

# internal docs not meant for public repo
docs/security/
docs/adr/

# dev artifacts
demo/
debug/

# local auth data (keep sample file tracked)
data/local-auth-store.json
data/local-auth-store.backup-*.json
data/release-manual-store.json
data/backups/
data/versions/
data/s3/
data/assistant-audit-log.json
data/support-suportes.json
data/user-notes.json
data/*.lock
data/*-debug.log

# Editor/IDE
.vscode/
.idea/

# Turbopack / Next.js internal files
.next/turbopack
.next/dev/lock

# Node module tooling logs
node_modules/**/lint.log

# Temporary files
*.tmp
.dev.pid
