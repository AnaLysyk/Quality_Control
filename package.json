{
  "name": "quality-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:logs": "bash scripts/clean-logs.sh || powershell -ExecutionPolicy Bypass -File scripts/clean-logs.ps1",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "build:clean": "npm run clean && npm run build",
    "dev:clean": "node scripts/dev-clean.js",
    "dev": "node scripts/dev-start.js --webpack",
    "dev:webpack": "node scripts/dev-start.js --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:ci": "cross-env NEXT_DISABLE_FONT_DOWNLOAD=1 next dev --webpack -p 3100 -H 127.0.0.1",
    "dev:ci:clean": "node scripts/clean-next.js && npm run dev:ci",
    "build": "node scripts/prisma-migrate-safe.js && next build",
    "start": "next start",
    "lint": "eslint --max-warnings 9999",
    "typecheck": "node scripts/clean-next.js && tsc --noEmit",
    "email:preview:access-requests": "tsx scripts/test-access-request-email-preview.ts",
    "test": "jest --config jest.config.ts --passWithNoTests --testMatch \"**/tests/**/*.test.ts?(x)\"",
    "test:coverage": "jest --config jest.config.ts --coverage --coverageReporters=lcov --coverageReporters=text --passWithNoTests --testMatch \"**/tests/**/*.test.ts?(x)\"",
    "test:biometrics": "jest --config jest.config.ts --runInBand tests/biometrics-fingerprint-processor.test.ts",
    "test:e2e": "cross-env E2E_USE_JSON=1 playwright test",
    "test:e2e:projects": "cross-env E2E_USE_JSON=1 playwright test --list",
    "test:e2e:headed": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PLAYWRIGHT_SCREENSHOT=on playwright test --headed",
    "test:e2e:ui": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PLAYWRIGHT_SCREENSHOT=on playwright test --ui",
    "test:e2e:debug": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PLAYWRIGHT_SCREENSHOT=on PWDEBUG=1 playwright test --debug",
    "test:e2e:edge": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_CHANNEL=msedge PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PLAYWRIGHT_SCREENSHOT=on playwright test --headed",
    "test:e2e:trace": "playwright show-trace",
    "backfill:company-integrations": "tsx scripts/backfill/company-integrations.ts",
    "test:e2e:smoke": "cross-env E2E_USE_JSON=1 playwright test --project=quality-smoke",
    "test:e2e:access": "cross-env E2E_USE_JSON=1 playwright test --project=quality-access",
    "test:e2e:cases": "cross-env E2E_USE_JSON=1 playwright test --project=quality-test-cases",
    "test:e2e:profile-cycle": "cross-env E2E_USE_JSON=1 playwright test tests-e2e/case-repository-profile-cycle.spec.ts --project=chromium",
    "test:e2e:automation-link": "cross-env E2E_USE_JSON=1 playwright test tests-e2e/test-case-automation-link.spec.ts --project=chromium",
    "test:e2e:runs": "cross-env E2E_USE_JSON=1 playwright test --project=quality-runs",
    "test:e2e:automation": "cross-env E2E_USE_JSON=1 playwright test --project=quality-automation",
    "test:e2e:dashboards": "cross-env E2E_USE_JSON=1 playwright test --project=quality-dashboards",
    "test:e2e:ai": "cross-env E2E_USE_JSON=1 playwright test --project=quality-ai",
    "test:e2e:visual": "cross-env E2E_USE_JSON=1 playwright test --project=quality-ui",
    "test:e2e:prod": "playwright test -c playwright.prod.config.ts --headed",
    "test:api": "node scripts/run-newman.mjs",
    "biometrics:attach": "tsx scripts/biometrics/run-local-attach.ts",
    "env:check": "tsx scripts/env-check.ts",
    "dev:watch": "powershell -ExecutionPolicy Bypass -File scripts/dev-watch.ps1",
    "dev:daemon": "node scripts/dev-daemon.js",
    "dev:stop": "node scripts/dev-stop.js",
    "create-admin": "npx tsx scripts/create-admin.ts",
    "create-ana-admin": "npx tsx scripts/create-ana-admin.ts",
    "seed:ana-admin": "npx tsx scripts/create-ana-admin.ts",
    "seed:mttr-goal": "tsx tests-e2e/utils/seed-mttr-goal.ts",
    "seed:run-defects": "tsx tests-e2e/utils/seed-run-defects.ts",
    "seed:risk": "tsx tests-e2e/utils/seed-risk.ts",
    "seed:runs-search-quality-sla": "tsx tests-e2e/utils/seed-runs-search-quality-sla.ts",
    "seed:quality-alert": "tsx scripts/seed.ts",
    "seed:dev-access": "prisma generate && tsx scripts/seed-dev-access.ts",
    "seed:griaule": "npx tsx scripts/seed-griaule.ts",
    "seed:demo": "npx tsx scripts/seed-demo.ts",
    "seed:all": "npm run seed:ana-admin && npm run seed:quality-alert && npm run seed:demo",
    "postinstall": "node scripts/fix-server-only.js",
    "db:check": "node scripts/test-db-connection.js",
    "migrate:upstash": "node tmp/migrate_to_upstash.js",
    "brain:sync": "tsx scripts/sync-brain.ts",
    "brain:maintenance": "tsx scripts/brain-maintenance.ts",
    "brain:reindex": "tsx scripts/sync-brain.ts",
    "brain:test": "jest --config jest.config.ts --runInBand __tests__/brain.test.ts",
    "test:brain:contracts": "jest --config jest.config.ts --runInBand tests/brain-ingest-contract.test.ts tests/brain-commands-confirmation.test.ts",
    "sonar:scan": "sonar-scanner",
    "sonar:scan:debug": "sonar-scanner -X",
    "sonar:issues": "node scripts/sonar-issues.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.61",
    "@aws-sdk/client-s3": "^3.975.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@upstash/redis": "^1.36.1",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.175",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "next": "16.2.9",
    "nodemailer": "^8.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.1.1",
    "recharts": "^3.5.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^6.4.14",
    "@types/papaparse": "^5.5.1",
    "@types/react": "^19",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-react-hooks": "7.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
