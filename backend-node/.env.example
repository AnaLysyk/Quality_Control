
PORT=3000
# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# Database URLs
# LOCAL (desenvolvimento, conexão direta, sem pooler):
DATABASE_URL="postgresql://postgres:<senha>@<host>.supabase.co:5432/postgres?sslmode=require"
#
# PRODUÇÃO/PREVIEW (Vercel):
# Use sempre o Session Pooler do Supabase (IPv4), exemplo real do projeto:
#
# DATABASE_URL="postgresql://postgres.glzoowczvjykxjxctjsq:mDWXm61Za8VqhjzR@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
#
# Não use db.glzoowczvjykxjxctjsq.supabase.co na Vercel!
# Não precisa de sslmode=disable nem workarounds.
#
# Prisma (produção, pooler):
POSTGRES_PRISMA_URL="postgresql://postgres.glzoowczvjykxjxctjsq:mDWXm61Za8VqhjzR@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# S3
S3_ENDPOINT=https://glzoowczvjykxjxctjsq.storage.supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_BUCKET=Test
