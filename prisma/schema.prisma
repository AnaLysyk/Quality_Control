// ============================================
// BRAIN MODELS - Grafo de Conhecimento
// ============================================

model BrainNode {
  id          String   @id @default(cuid())
  type        String   // "Company", "Application", "Module", "Screen", "Ticket", "Defect", "TestRun", "User", "Note", "Release", "Integration", "AuditEvent", "Route"
  label       String   // nome ou identificador legível
  description String?  // resumo do que é

  refType     String?  // nome do modelo original (ex: "Company", "Application")
  refId       String?  // ID no modelo original

  metadata    Json?    // custom fields: {severity, status, owner, tags, etc}
  importanceScore Float @default(0)
  riskScore       Float @default(0)
  qualityScore    Float @default(0)
  privacyLevel    String @default("company") // private | company | project | global | restricted
  confidenceLevel Float  @default(0.8)

  outgoing    BrainEdge[] @relation("OutgoingEdges")
  incoming    BrainEdge[] @relation("IncomingEdges")

  memories    BrainMemory[]
  suggestions BrainSuggestion[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([refType, refId])
  @@index([label])
  @@index([privacyLevel])
  @@index([importanceScore])
  @@index([riskScore])
  @@index([qualityScore])
}

model BrainEdge {
  id        String   @id @default(cuid())
  fromId    String
  toId      String

  type      String   // "HAS_APPLICATION", "HAS_MODULE", "HAS_SCREEN", "CREATED_BY", "ASSIGNED_TO", "BLOCKS", "BELONGS_TO", "USES_INTEGRATION", "RELATES_TO", "GENERATED_EVENT", "IMPACTED_BY", "HAS_ROUTE", "MEMBER_OF", "FOUND_IN", "RELEASED_IN"

  weight    Float?   // importância 0-1, opcional
  metadata  Json?    // custom fields

  from      BrainNode @relation("OutgoingEdges", fields: [fromId], references: [id], onDelete: Cascade)
  to        BrainNode @relation("IncomingEdges", fields: [toId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([fromId, toId, type])
  @@index([type])
  @@index([fromId])
  @@index([toId])
}

model BrainMemory {
  id          String   @id @default(cuid())

  title       String   // "Decisão: usar mock em testes", "Regra: validar email antes", etc
  summary     String   // resumo em 1-3 frases
  memoryType  String   // "DECISION", "RULE", "PATTERN", "CONTEXT", "EXCEPTION", "TECHNICAL_NOTE"

  importance  Int      @default(1)  // 1-5 stars

  relatedNodeIds Json?  // lista de IDs de nós conectados: ["node1", "node2"]

  sourceType  String?  // "CONVERSATION", "TICKET", "DEFECT", "MANUAL"
  sourceId    String?  // ID da fonte

  status      String   @default("ACTIVE")  // "ACTIVE", "ARCHIVED", "INVALID"

  metadata    Json?    // tags, autor, validação_status, etc

  node        BrainNode? @relation(fields: [nodeId], references: [id])
  nodeId      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memoryType])
  @@index([importance])
  @@index([status])
}

model BrainAuditLog {
  id        String   @id @default(cuid())

  action    String   // "CREATE_NODE", "UPDATE_NODE", "DELETE_NODE", "CREATE_EDGE", "DELETE_EDGE", "ADD_MEMORY", "UPDATE_MEMORY", "INITIAL_SYNC"
  entityType String  // "BrainNode", "BrainEdge", "BrainMemory"
  entityId  String

  before    Json?    // estado anterior (para delete/update)
  after     Json?    // estado novo

  userId    String?  // quem fez (se disponível)
  reason    String?  // por quê

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model BrainSuggestion {
  id            String   @id @default(cuid())
  companySlug   String?
  projectId     String?
  targetNodeId  String
  type          String
  title         String
  description   String
  confidence    Float    @default(0.5)
  status        String   @default("suggested") // suggested | accepted | rejected | resolved | archived
  createdBy     String   @default("system")
  riskLevel     String   @default("medium") // low | medium | high
  requiresReview Boolean @default(true)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  targetNode BrainNode @relation(fields: [targetNodeId], references: [id], onDelete: Cascade)
  inboxItems  BrainInboxItem[]

  @@index([companySlug])
  @@index([targetNodeId])
  @@index([status])
  @@index([type])
}

model BrainInboxItem {
  id           String   @id @default(cuid())
  kind         String   // suggestion | duplicate | gap | failed_event | doc_unlinked | script_without_case
  companySlug  String?
  status       String   @default("pending") // pending | approved | rejected | merged | archived | needs_review
  title        String
  summary      String?
  payload      Json?
  suggestionId String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  suggestion BrainSuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)

  @@index([companySlug])
  @@index([status])
  @@index([kind])
}

model BrainWorkspace {
  id          String   @id @default(cuid())
  userId      String
  companySlug String?
  name        String
  description String?
  status      String   @default("active") // active | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nodes      BrainWorkspaceNode[]
  edges      BrainWorkspaceEdge[]
  savedViews BrainSavedView[]

  @@index([userId])
  @@index([companySlug])
  @@index([status])
}

model BrainWorkspaceNode {
  id          String   @id @default(cuid())
  workspaceId String
  brainNodeId String?
  label       String
  type        String
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace BrainWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([brainNodeId])
}

model BrainWorkspaceEdge {
  id          String   @id @default(cuid())
  workspaceId String
  fromNodeId  String
  toNodeId    String
  type        String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace BrainWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model BrainSavedView {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  mode        String   @default("graph") // graph | list | table | tree | compare
  filters     Json?
  layout      Json?
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace BrainWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([mode])
}

model BrainRetentionPolicy {
  id                    String   @id @default(cuid())
  scope                 String   @unique // default | company:{slug}
  eventDays             Int      @default(90)
  agentRunDays          Int      @default(90)
  rejectedMemoryDays    Int      @default(30)
  heavyArtifactDays     Int      @default(30)
  staleMemoryDays       Int      @default(30)
  weeklyReviewEnabled   Boolean  @default(true)
  metadata              Json?
  updatedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([scope])
}

model BrainProviderConfig {
  id               String   @id @default(cuid())
  provider         String
  enabled          Boolean  @default(true)
  model            String?
  models           Json?
  priority         Int      @default(100)
  dailyRequestLimit Int?
  dailyTokenLimit  Int?
  strictFreeModels Boolean  @default(true)
  timeoutMs        Int?
  maxOutputTokens  Int?
  metadata         Json?
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([provider])
  @@index([enabled])
  @@index([priority])
  @@map("brain_provider_configs")
}

model BrainSourceConfig {
  id                     String   @id @default(cuid())
  name                   String
  description            String?
  sourceType             String
  provider               String?
  status                 String   @default("draft")
  scopeType              String   @default("global")
  companyId              String?
  companySlug            String?
  projectId              String?
  projectSlug            String?
  ownerUserId            String?
  allowedRoles           Json?
  allowedUsers           Json?
  requiredPermission     String?
  environment            String   @default("dev")
  priority               Int      @default(50)
  useForCompanyContext   Boolean  @default(false)
  useForGeneralQuestions Boolean  @default(true)
  useForRagIngestion     Boolean  @default(false)
  useForLiveQuery        Boolean  @default(false)
  config                 Json     @default("{}")
  lastSyncAt             DateTime?
  lastSuccessAt          DateTime?
  lastErrorAt            DateTime?
  lastErrorMessage       String?
  createdBy              String?
  updatedBy              String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  secrets                BrainSourceSecret[]
  auditLogs              BrainSourceAuditLog[]
  syncLogs               BrainSourceSyncLog[]

  @@index([sourceType])
  @@index([status])
  @@index([scopeType])
  @@index([companyId])
  @@index([companySlug])
  @@index([projectId])
  @@index([ownerUserId])
  @@map("brain_source_configs")
}

model BrainSourceSecret {
  id             String   @id @default(cuid())
  sourceId       String
  key            String
  label          String?
  maskedValue    String?
  encryptedValue String
  encryptionHint String?
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  source         BrainSourceConfig @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, key])
  @@index([sourceId])
  @@map("brain_source_secrets")
}

model BrainSourceAuditLog {
  id        String   @id @default(cuid())
  sourceId  String?
  action    String
  before    Json?
  after     Json?
  userId    String?
  reason    String?
  createdAt DateTime @default(now())

  source    BrainSourceConfig? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([sourceId])
  @@index([action])
  @@index([createdAt])
  @@map("brain_source_audit_logs")
}

model BrainSourceSyncLog {
  id         String   @id @default(cuid())
  sourceId   String
  kind       String   @default("test")
  status     String
  message    String?
  metadata   Json?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  createdAt  DateTime @default(now())

  source     BrainSourceConfig @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([status])
  @@index([kind])
  @@index([createdAt])
  @@map("brain_source_sync_logs")
}

model BrainBehaviorProfile {
  id             String   @id @default(cuid())
  name           String
  description    String?
  instructions   String
  tone           String?
  formality      String?
  responseLength String?
  rules          Json?
  scopeType      String   @default("user")
  companyId      String?
  projectId      String?
  ownerUserId    String?
  isSystem       Boolean  @default(false)
  status         String   @default("active")
  version        Int      @default(1)
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    BrainBehaviorProfileAssignment[]

  @@index([scopeType])
  @@index([companyId])
  @@index([projectId])
  @@index([ownerUserId])
  @@index([status])
  @@map("brain_behavior_profiles")
}

model BrainBehaviorProfileAssignment {
  id        String   @id @default(cuid())
  scopeType String
  scopeId   String
  surface   String
  profileId String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile   BrainBehaviorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([scopeType, scopeId, surface])
  @@index([profileId])
  @@map("brain_behavior_profile_assignments")
}

// Prisma Schema — Quality Control
// Provider: PostgreSQL (Render)
// Gerado automaticamente com base nos tipos do projeto

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  name                 String
  full_name            String?
  email                String    @unique
  user                 String?   @unique
  password_hash        String
  globalRole           String?
  role                 Role?     @default(user)
  status               String    @default("active")
  active               Boolean   @default(true)
  is_global_admin      Boolean   @default(false)
  avatar_key           String?
  avatar_url           String?
  job_title            String?
  linkedin_url         String?
  phone                String?
  default_company_slug String?
  created_by_company_id String?
  home_company_id       String?
  user_origin           String    @default("testing_company")
  user_scope            String    @default("shared")
  allow_multi_company_link Boolean @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  memberships        Membership[]
  links              UserCompanyLink[]
  tickets            Ticket[]                @relation("TicketCreatedBy")
  assignedTickets    Ticket[]                @relation("TicketAssignedTo")
  ticketComments     TicketComment[]
  notifications      UserNotification[]
  notes              UserNote[]
  accessRequests     AccessRequest[]
  requests           Request[]
  permissionOverride UserPermissionOverride?

  @@map("users")
}

model Company {
  id                 String               @id @default(cuid())
  name               String
  company_name       String?
  slug               String               @unique
  status             String               @default("active")
  active             Boolean              @default(true)
  tax_id             String?
  address            String?
  phone              String?
  website            String?
  logo_url           String?
  docs_link          String?
  notes              String?
  cep                String?
  linkedin_url       String?
  qase_token         String?
  qase_project_code  String? // legacy, use qase_project_codes for multi-project support
  qase_project_codes String[]             @default([]) // canonical: always use this for new code
  jira_base_url      String?
  jira_email         String?
  jira_api_token     String?
  integration_mode   String?              @default("none")
  integrations       CompanyIntegration[]
  short_description  String?
  internal_notes     String?
  created_by         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  memberships  Membership[]
  links        UserCompanyLink[]
  tickets      Ticket[]
  releases     Release[]
  applications Application[]
  projects     Project[]

  @@map("companies")
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id           String    @id @default(cuid())
  companyId    String
  slug         String
  name         String
  description  String?
  status       String    @default("active")
  color        String?
  iconKey      String?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?
  archivedById String?

  // Integração por projeto: credenciais (token/base URL) continuam na empresa
  // (Company.jira_*/qase_token); aqui só o identificador do projeto dentro
  // daquela integração — mesmo modelo do Jira/Qase reais (1 site, N projetos).
  qaseProjectCode        String?
  jiraProjectKey         String?
  manualCreationDisabled Boolean @default(false)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  testPlans TestPlan[]
  testRuns  TestRun[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("projects")
}

enum IntegrationType {
  QASE
  JIRA
  MANUAL
  OTHER
}

// Enum for application roles — values match existing string roles in DB
enum Role {
  admin
  it_dev
  dev
  company_admin
  company
  user
  viewer
  support
  leader_tc
  technical_support
}

model CompanyIntegration {
  id        String          @id @default(cuid())
  companyId String
  type      IntegrationType
  // store credentials/config per integration as JSON (encrypted at rest recommended)
  config    Json?
  createdAt DateTime        @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_integrations")
}

model Membership {
  id                String   @id @default(cuid())
  userId            String
  companyId         String
  role              Role?    @default(user)
  capabilities      String[] @default([])
  // Empty array = sem restrição (enxerga todos os projetos da empresa). Só é aplicado
  // para papéis escopados por projeto (company_user, testing_company_user).
  allowedProjectIds String[] @default([])
  createdAt         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("memberships")
}

model UserCompanyLink {
  id                   String   @id @default(cuid())
  userId               String
  companyId            String
  role                 Role?
  permissions          String[] @default([])
  active               Boolean  @default(true)

  // Extended metadata (migration: 20260510214000_expand_user_company_link_metadata)
  roleInCompany        String?
  allowedApplicationIds String[] @default([])
  allowedModuleIds     String[] @default([])
  status               String   @default("active")
  linkedAt             DateTime @default(now())
  linkedBy             String?
  updatedAt            DateTime @updatedAt
  updatedBy            String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("user_company_links")
}

// ─── Releases ────────────────────────────────────────────────────────────────

model Release {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  summary      String?
  app          String?
  project      String?
  qaseProject  String?
  category     String?
  kind         String?   @default("run")
  runSlug      String?
  runName      String?
  companySlug  String?
  companyId    String?
  clientId     String?
  clientName   String?
  radis        String?
  environments String[]  @default([])
  source       String    @default("MANUAL")
  status       String    @default("DRAFT")
  runId        Int?
  statsPass    Int       @default(0)
  statsFail    Int       @default(0)
  statsBlocked Int       @default(0)
  statsNotRun  Int       @default(0)
  observations String?
  createdByUserId String?
  createdByName String?
  assignedToUserId String?
  assignedToName String?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company Company?      @relation(fields: [companyId], references: [id])
  cases   ReleaseCase[]

  @@map("releases")
}

model ReleaseCase {
  id        String  @id @default(cuid())
  releaseId String
  title     String?
  link      String?
  status    String  @default("NOT_RUN")
  bug       String?
  fromApi   Boolean @default(false)
  metadata  Json?

  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@map("release_cases")
}

// ─── Tickets / Suporte ───────────────────────────────────────────────────────

model Ticket {
  id               String   @id @default(cuid())
  code             String
  title            String
  description      String
  status           String   @default("backlog")
  type             String   @default("tarefa")
  priority         String   @default("medium")
  tags             String[] @default([])
  companySlug      String?
  companyId        String?
  createdBy        String
  createdByName    String?
  createdByEmail   String?
  assignedToUserId String?
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company   Company?         @relation(fields: [companyId], references: [id])
  creator   User             @relation("TicketCreatedBy", fields: [createdBy], references: [id])
  assignee  User?            @relation("TicketAssignedTo", fields: [assignedToUserId], references: [id])
  comments  TicketComment[]
  events    TicketEvent[]
  reactions TicketReaction[]

  @@map("tickets")
}

model TicketComment {
  id           String    @id @default(cuid())
  ticketId     String
  authorUserId String
  authorName   String?
  body         String
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  ticket    Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorUserId], references: [id])
  reactions TicketReaction[]

  @@map("ticket_comments")
}

model TicketEvent {
  id          String   @id @default(cuid())
  ticketId    String
  type        String
  payload     Json?
  actorUserId String?
  createdAt   DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_events")
}

model TicketReaction {
  id        String   @id @default(cuid())
  ticketId  String
  commentId String
  userId    String
  type      String   @default("like")
  createdAt DateTime @default(now())

  ticket  Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment TicketComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, type])
  @@map("ticket_reactions")
}

// ─── User ↔ Company join (seed scripts) ─────────────────────────────────────

model UserCompany {
  id         String @id @default(cuid())
  user_id    String
  company_id String
  role       Role   @default(user)

  @@unique([user_id, company_id], name: "user_id_company_id")
  @@map("user_companies")
}

// ─── Release Manual ──────────────────────────────────────────────────────────

model ReleaseManual {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("draft")
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("release_manuals")
}

// ─── Test Run ─────────────────────────────────────────────────────────────────

model TestRun {
  id           String    @id @default(cuid())
  companyId    String?
  projectId    String?
  planId       String?
  title        String    @default("Execução manual")
  source       String    @default("manual") // manual | playwright | integration
  browser      String?
  baseUrl      String?
  headless     Boolean   @default(true)
  timeoutMs    Int?
  workers      Int?
  retries      Int?
  screenshotOn String?
  videoOn      String?
  traceOn      String?
  status       String    @default("pending") // pending | running | passed | failed | error
  passCount    Int       @default(0)
  failCount    Int       @default(0)
  skipCount    Int       @default(0)
  totalCount   Int       @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  archivedAt   DateTime?
  archivedById String?

  project  Project?          @relation(fields: [projectId], references: [id])
  plan     TestPlan?         @relation(fields: [planId], references: [id])
  results  TestRunResult[]

  @@index([companyId])
  @@index([projectId])
  @@index([planId])
  @@index([status])
  @@map("test_runs")
}

model TestRunResult {
  id         String   @id @default(cuid())
  runId      String
  caseId     String?
  title      String
  status     String   // passed | failed | skipped | flaky
  durationMs Int?
  errorMsg   String?
  filePath   String?
  retries    Int      @default(0)
  createdAt  DateTime @default(now())

  run TestRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([caseId])
  @@map("test_run_results")
}

// ─── Test Plan ────────────────────────────────────────────────────────────────

model TestPlan {
  id          String   @id @default(cuid())
  companyId   String
  projectId   String?
  title       String
  description String?
  status      String   @default("draft") // draft | active | archived
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  archivedAt   DateTime?
  archivedById String?

  project Project?       @relation(fields: [projectId], references: [id])
  items   TestPlanItem[]
  runs    TestRun[]

  @@index([companyId])
  @@index([projectId])
  @@map("test_plans")
}

model TestPlanItem {
  id        String   @id @default(cuid())
  planId    String
  caseId    String?
  title     String
  status    String   @default("not_run") // not_run | passed | failed | blocked | skipped
  order     Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

