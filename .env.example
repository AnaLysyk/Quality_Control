# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase
#
# IMPORTANTE:
# - Variáveis NEXT_PUBLIC_* ficam disponíveis no browser (anon key pode, service role NÃO pode).
# - Após alterar .env.local, reinicie o dev server.

# Auth (recommended)
# Se você não usa mais Supabase Auth, habilite o modo JWT:
SUPABASE_DISABLED=""
JWT_SECRET=""

# Database (Postgres) — necessário para persistência de usuários/empresas (server-only)
# Este projeto usa @vercel/postgres. Configure pelo menos:
POSTGRES_URL=""
# Opcional (recomendado): conexão direta sem pooling
POSTGRES_URL_NON_POOLING=""

# Aliases usados por alguns scripts/documentos
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# Optional: Upstash Redis / Vercel KV (server-only)
# Configure only if you enable Redis features.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
KV_REST_API_READ_ONLY_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: protect /api/public/redis/ping
REDIS_PING_SECRET=""

# Supabase (legacy; only if still used)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Public base URL of this app (important for auth email redirects in production)
# Example (Vercel prod domain): https://painel-qa.example.com
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Opcional (server-only, legacy): necessário para rotas admin/server-side que usam service role
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Local-only: RLS validation helper (do not commit real tokens/passwords)
# Prefer JWT to avoid storing passwords:
# ACCESS_TOKEN="YOUR_AUTH_JWT"
# Alternatively:
# TEST_EMAIL="user@example.com"
# TEST_PASSWORD="password"

# Optional: override the deployed Edge Function URL used by /api/auth/reset-via-token
# If not set, the app derives it from NEXT_PUBLIC_SUPABASE_URL.
# RESET_VIA_TOKEN_FN_URL="https://YOUR_PROJECT.supabase.co/functions/v1/reset-via-token"
