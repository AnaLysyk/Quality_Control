import type { BrainEdge, BrainNode } from "../_types/brain.types";
import type { BrainNodeStatus, BrainNodeType } from "../_types/brain.types";

export type BrainLayoutNode = BrainNode & {
  x: number;
  y: number;
  radius: number;
  connectedCount: number;
  isOrphan: boolean;
};

const MODULE_ORDER = ["Solicitacoes", "Empresas", "Defeitos", "Automacao", "Documentos", "Usuarios", "Permissoes", "Logs", "Chat/Brain"];

function radiusForNode(node: BrainNode) {
  if (node.size === "lg" || node.type === "module") return 46;
  if (node.size === "md") return 34;
  return 25;
}

function moduleIndex(module: string) {
  const index = MODULE_ORDER.indexOf(module);
  return index >= 0 ? index : MODULE_ORDER.length;
}

function stablePercent(value: number) {
  return Number(value.toFixed(4));
}

export function getConnectedNodeIds(edges: BrainEdge[]) {
  return new Set(edges.flatMap((edge) => [edge.source, edge.target]));
}

export function getModuleNames(nodes: BrainNode[]) {
  return Array.from(new Set(nodes.map((node) => node.module))).sort((a, b) => moduleIndex(a) - moduleIndex(b));
}

type VisibleGraphOptions = {
  moduleFilter: string | null;
  showOrphansOnly: boolean;
  showPendingOnly: boolean;
  searchText?: string;
  focusNodeId?: string | null;
  localGraphOnly?: boolean;
  nodeType?: BrainNodeType | "all";
  nodeStatus?: BrainNodeStatus | "all";
  period?: "all" | "today" | "7d" | "30d";
  companyId?: string | null;
  projectId?: string | null;
  profileType?: string | null;
  subjectId?: string | null;
  subjectKind?: "profile" | "user" | "company" | null;
};

function normalize(value: string) {
  return value
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim();
}

function belongsToSelectedCompany(node: BrainNode, companyId: string | null) {
  if (!companyId) return true;
  if (node.companyId) return node.companyId === companyId;
  return node.type === "company" || node.metadata?.isBrainCore === true || node.metadata?.isContextCore === true;
}

function belongsToSelectedProject(node: BrainNode, projectId: string | null) {
  if (!projectId) return true;
  if (node.projectId) return node.projectId === projectId;
  return node.type === "company" || node.type === "project" || node.metadata?.isBrainCore === true || node.metadata?.isContextCore === true;
}

export function getVisibleGraph(nodes: BrainNode[], edges: BrainEdge[], options: VisibleGraphOptions) {
  const {
    moduleFilter,
    showOrphansOnly,
    showPendingOnly,
    searchText = "",
    focusNodeId = null,
    localGraphOnly = false,
    nodeType = "all",
    nodeStatus = "all",
    period = "all",
    companyId = null,
    projectId = null,
    profileType = null,
    subjectId = null,
    subjectKind = null,
  } = options;

  const connected = getConnectedNodeIds(edges);
  const localIds = new Set<string>();

  if (localGraphOnly && focusNodeId) {
    localIds.add(focusNodeId);
    edges.forEach((edge) => {
      if (edge.source === focusNodeId) localIds.add(edge.target);
      if (edge.target === focusNodeId) localIds.add(edge.source);
    });
  }

  const query = normalize(searchText);
  const queryTokens = query.split(/\s+/).filter(Boolean);

  const visibleNodes = nodes.filter((node) => {
    if (profileType && node.metadata?.profileType && node.metadata.profileType !== profileType) return false;

    if (subjectKind === "user" && subjectId) {
      const createdByMatch = node.createdBy === subjectId;
      const actorMatch = node.metadata?.actorUserId === subjectId;
      const directUserNode = node.id === subjectId || node.id === `user:${subjectId}`;
      if (!createdByMatch && !actorMatch && !directUserNode) return false;
    }

    if (subjectKind === "company" && subjectId) {
      if (node.companyId && node.companyId !== subjectId) return false;
    } else {
      if (!belongsToSelectedCompany(node, companyId)) return false;
      if (!belongsToSelectedProject(node, projectId)) return false;
    }
    if (moduleFilter && node.module !== moduleFilter) return false;
    if (nodeType !== "all" && node.type !== nodeType) return false;
    if (nodeStatus !== "all" && node.status !== nodeStatus) return false;
    if (localGraphOnly && focusNodeId && !localIds.has(node.id)) return false;
    if (showOrphansOnly && connected.has(node.id)) return false;
    if (showPendingOnly && !["pending", "missing", "warning", "error"].includes(node.status)) return false;

    if (period !== "all" && node.createdAt) {
      const createdAt = new Date(node.createdAt).getTime();

      if (Number.isFinite(createdAt)) {
        const ageMs = Date.now() - createdAt;

        if (period === "today" && new Date(node.createdAt).toDateString() !== new Date().toDateString()) return false;
        if (period === "7d" && ageMs > 7 * 24 * 60 * 60 * 1000) return false;
        if (period === "30d" && ageMs > 30 * 24 * 60 * 60 * 1000) return false;
      }
    }

    if (queryTokens.length) {
      const haystack = normalize(
        [
          node.label,
          node.module,
          node.description,
          node.information,
          node.status,
          node.type,
          node.companyName,
          node.projectName,
          node.refType,
          node.refId,
          typeof node.metadata?.route === "string" ? node.metadata.route : "",
          typeof node.metadata?.source === "string" ? node.metadata.source : "",
          typeof node.metadata?.entityType === "string" ? node.metadata.entityType : "",
          ...(node.missingKnowledge ?? []),
        ]
          .filter(Boolean)
          .join(" "),
      );

      if (!queryTokens.some((token) => haystack.includes(token))) return false;
    }

    return true;
  });

  const ids = new Set(visibleNodes.map((node) => node.id));
  const visibleEdges = edges.filter((edge) => ids.has(edge.source) && ids.has(edge.target));

  return { nodes: visibleNodes, edges: visibleEdges };
}

export function layoutBrainGraph(nodes: BrainNode[], edges: BrainEdge[]): BrainLayoutNode[] {
  const modules = getModuleNames(nodes);
  const connected = getConnectedNodeIds(edges);
  const connectionCounts = edges.reduce<Record<string, number>>((acc, edge) => {
    acc[edge.source] = (acc[edge.source] ?? 0) + 1;
    acc[edge.target] = (acc[edge.target] ?? 0) + 1;
    return acc;
  }, {});

  const centerX = 50;
  const centerY = 50;
  const moduleStep = modules.length > 1 ? 360 / modules.length : 360;
  const modulePositions = new Map<string, { x: number; y: number }>();

  modules.forEach((moduleName, index) => {
    const angle = (-95 + index * moduleStep) * (Math.PI / 180);

    modulePositions.set(moduleName, {
      x: stablePercent(centerX + Math.cos(angle) * 31),
      y: stablePercent(centerY + Math.sin(angle) * 31),
    });
  });

  return nodes.map((node, index) => {
    const modulePosition = modulePositions.get(node.module) ?? { x: centerX, y: centerY };

    if (node.type === "module") {
      return {
        ...node,
        x: stablePercent(modulePosition.x),
        y: stablePercent(modulePosition.y),
        radius: radiusForNode(node),
        connectedCount: connectionCounts[node.id] ?? 0,
        isOrphan: !connected.has(node.id),
      };
    }

    const siblings = nodes.filter((candidate) => candidate.module === node.module && candidate.type !== "module");
    const siblingIndex = Math.max(0, siblings.findIndex((candidate) => candidate.id === node.id));
    const angle = (siblingIndex / Math.max(1, siblings.length)) * Math.PI * 2 + (index % 3) * 0.18;
    const distance = 9 + (siblingIndex % 3) * 4.6;

    return {
      ...node,
      x: stablePercent(Math.max(6, Math.min(94, modulePosition.x + Math.cos(angle) * distance))),
      y: stablePercent(Math.max(8, Math.min(92, modulePosition.y + Math.sin(angle) * distance))),
      radius: radiusForNode(node),
      connectedCount: connectionCounts[node.id] ?? 0,
      isOrphan: !connected.has(node.id),
    };
  });
}

export function describeInformation(node: BrainNode | null, nodes: BrainNode[], edges: BrainEdge[]) {
  if (!node) return "Selecione um nó para ver a informação formada.";
  if (node.information) return node.information;

  const related = edges
    .filter((edge) => edge.source === node.id || edge.target === node.id)
    .map((edge) => {
      const otherId = edge.source === node.id ? edge.target : edge.source;
      const other = nodes.find((candidate) => candidate.id === otherId);
      return other ? `${edge.label} ${other.label}` : edge.label;
    });

  if (!related.length) return `${node.label} é um conhecimento isolado. Ainda não forma informação completa com outros nós.`;

  return `${node.label} forma informação ao se conectar com: ${related.slice(0, 5).join("; ")}.`;
}

