{
  "name": "painel-qa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "dev:clean": "node scripts/dev-clean.js",
    "dev": "cross-env NEXT_DISABLE_TURBOPACK=1 next dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:ci": "next dev",
    "build": "npx prisma generate && next build",
    "build:backend": "npm --prefix backend run build",
    "start": "next start",
    "start:backend": "npm --prefix backend run start",
    "lint": "eslint --max-warnings 9999",
    "test": "jest --config jest.config.ts --passWithNoTests --testMatch \"**/tests/**/*.test.ts?(x)\"",
    "test:backend": "npm --prefix backend run test",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:prod": "playwright test -c playwright.prod.config.ts",
    "test:api": "node scripts/run-newman.mjs",
    "env:check": "tsx scripts/env-check.ts",
    "dev:daemon": "node scripts/dev-daemon.js",
    "dev:stop": "node scripts/dev-stop.js",
    "create-admin": "npx tsx scripts/create-admin.ts",
    "rls:check:global-admins": "node scripts/rls-check-global-admins.mjs",
    "edge:test:cron-snapshots": "node scripts/test-cron-snapshots-api.mjs",
    "seed:mttr-goal": "tsx tests-e2e/utils/seed-mttr-goal.ts",
    "seed:run-defects": "tsx tests-e2e/utils/seed-run-defects.ts",
    "seed:risk": "tsx tests-e2e/utils/seed-risk.ts",
    "seed:runs-search-quality-sla": "tsx tests-e2e/utils/seed-runs-search-quality-sla.ts",
    "seed:quality-alert": "tsx tests-e2e/utils/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.3.0",
    "@supabase/supabase-js": "^2.93.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@upstash/redis": "^1.36.1",
    "@vercel/postgres": "^0.10.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.555.0",
    "next": "^16.1.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.8",
    "papaparse": "^5.5.3",
    "pg": "^8.17.1",
    "postgres": "^3.4.8",
    "prisma": "^7.3.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.5.1",
    "remark-gfm": "^4.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/date-fns": "^2.5.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.30",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^6.4.14",
    "@types/papaparse": "^5.5.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.9.2",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.5",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
