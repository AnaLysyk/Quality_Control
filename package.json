{
  "name": "quality-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "build:clean": "npm run clean && npm run build",
    "dev:clean": "node scripts/dev-clean.js",
    "dev": "next dev --webpack",
    "dev:webpack": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:ci": "next dev --turbo",
    "build": "node scripts/prisma-migrate-safe.js && next build",
    "start": "next start",
    "lint": "eslint --max-warnings 9999",
    "test": "jest --config jest.config.ts --passWithNoTests --testMatch \"**/tests/**/*.test.ts?(x)\"",
    "test:e2e": "cross-env E2E_USE_JSON=1 playwright test",
    "backfill:company-integrations": "tsx scripts/backfill/company-integrations.ts",
    "test:e2e:smoke": "cross-env E2E_USE_JSON=1 playwright test --grep @smoke",
    "test:e2e:prod": "playwright test -c playwright.prod.config.ts",
    "test:api": "node scripts/run-newman.mjs",
    "env:check": "tsx scripts/env-check.ts",
    "dev:daemon": "node scripts/dev-daemon.js",
    "dev:stop": "node scripts/dev-stop.js",
    "create-admin": "npx tsx scripts/create-admin.ts",
    "create-ana-admin": "npx tsx scripts/create-ana-admin.ts",
    "seed:ana-admin": "npx tsx scripts/create-ana-admin.ts",
    "seed:mttr-goal": "tsx tests-e2e/utils/seed-mttr-goal.ts",
    "seed:run-defects": "tsx tests-e2e/utils/seed-run-defects.ts",
    "seed:risk": "tsx tests-e2e/utils/seed-risk.ts",
    "seed:runs-search-quality-sla": "tsx tests-e2e/utils/seed-runs-search-quality-sla.ts",
    "seed:quality-alert": "tsx tests-e2e/utils/seed.ts",
    "seed:griaule": "npx tsx scripts/seed-griaule.ts",
    "seed:all": "npm run seed:ana-admin && npm run seed:quality-alert && npm run seed:griaule",
    "postinstall": "node scripts/fix-server-only.js",
    "db:check": "node scripts/test-db-connection.js",
    "migrate:upstash": "node tmp/migrate_to_upstash.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@upstash/redis": "^1.36.1",
    "ai": "^6.0.79",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "next": "^16.1.1",
    "nodemailer": "^8.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.1.1",
    "recharts": "^3.5.1",
    "server-only": "^0.0.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^6.4.14",
    "@types/papaparse": "^5.5.1",
    "@types/react": "^19",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
