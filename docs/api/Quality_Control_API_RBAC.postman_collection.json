{
  "info": {
    "name": "Quality Control API - RBAC + Company",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colecao oficial para testar Auth, Health e RBAC/Company no backend."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "login",
      "value": "EMAIL_AQUI"
    },
    {
      "key": "password",
      "value": "SENHA_AQUI"
    },
    {
      "key": "companyId",
      "value": ""
    },
    {
      "key": "isGlobalAdmin",
      "value": ""
    },
    {
      "key": "companyIdNegative",
      "value": ""
    },
    {
      "key": "s3_prefix",
      "value": ""
    },
    {
      "key": "s3_object_key",
      "value": "uploads/teste.txt"
    },
    {
      "key": "s3_upload_file_path",
      "value": "tests-e2e/fixtures/s3-upload.txt"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Health - status 200', () => {\n  pm.response.to.have.status(200);\n});",
                  "const json = pm.response.json();",
                  "pm.test('Health - resposta ok', () => {\n  pm.expect(json.status).to.eql('ok');\n});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"{{login}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login - status 200 ou 201', () => {\n  pm.expect([200,201]).to.include(pm.response.code);\n});",
                  "const json = pm.response.json();",
                  "pm.test('Login - token presente', () => {\n  pm.expect(json.session).to.have.property('access_token');\n});",
                  "pm.environment.set('auth_token', json.session.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Me - status 200', () => {\n  pm.response.to.have.status(200);\n});",
                  "const json = pm.response.json();",
                  "pm.test('Me - usuario presente', () => {\n  pm.expect(json.user).to.exist;\n});",
                  "const companyId = json?.user?.companyId || json?.user?.clientId;",
                  "const isGlobalAdmin = json?.user?.isGlobalAdmin === true;",
                  "pm.environment.set('isGlobalAdmin', isGlobalAdmin ? 'true' : 'false');",
                  "pm.test('Me - global admin OU companyId', () => {\n  pm.expect(json.user.isGlobalAdmin === true || !!companyId).to.be.true;\n});",
                  "if (companyId) { pm.environment.set('companyId', companyId); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Qase (RBAC + Company)",
      "item": [
        {
          "name": "POST Create Country (admin only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Brazil\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/countries?companyId={{companyId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "countries"
              ],
              "query": [
                {
                  "key": "companyId",
                  "value": "{{companyId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Countries - status 201', () => {\n  pm.response.to.have.status(201);\n});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST Create Country (rbac forbidden)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const companyId = pm.environment.get('companyId');",
                  "const negative = companyId ? `${companyId}-forbidden` : '__invalid__';",
                  "pm.environment.set('companyIdNegative', negative);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const isGlobalAdmin = pm.environment.get('isGlobalAdmin') === 'true';",
                  "if (isGlobalAdmin) {",
                  "  pm.test('Countries forbidden - global admin bypass', () => {\n    pm.expect([200,201]).to.include(pm.response.code);\n  });",
                  "} else {",
                  "  pm.test('Countries forbidden - status 403', () => {\n    pm.response.to.have.status(403);\n  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Brazil Forbidden\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/countries?companyId={{companyIdNegative}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "countries"
              ],
              "query": [
                {
                  "key": "companyId",
                  "value": "{{companyIdNegative}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "S3",
      "item": [
        {
          "name": "GET S3 Buckets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/s3/buckets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "s3",
                "buckets"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('S3 Buckets - status 200', () => {\n  pm.response.to.have.status(200);\n});",
                  "const json = pm.response.json();",
                  "pm.test('S3 Buckets - ok true', () => {\n  pm.expect(json.ok).to.eql(true);\n});",
                  "pm.test('S3 Buckets - array', () => {\n  pm.expect(json.buckets).to.be.an('array');\n});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET S3 Objects",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/s3/objects?prefix={{s3_prefix}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "s3",
                "objects"
              ],
              "query": [
                {
                  "key": "prefix",
                  "value": "{{s3_prefix}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('S3 Objects - status 200', () => {\n  pm.response.to.have.status(200);\n});",
                  "const json = pm.response.json();",
                  "pm.test('S3 Objects - ok true', () => {\n  pm.expect(json.ok).to.eql(true);\n});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST S3 Upload",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "key",
                  "value": "{{s3_object_key}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/s3/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "s3",
                "upload"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const status = pm.response.code;",
                  "const bodyText = pm.response.text() || '';",
                  "const missingFile = status === 400 && /missing file/i.test(bodyText);",
                  "pm.test('S3 Upload - status 200 (ou 400 se arquivo nao enviado)', () => {\n  pm.expect([200,201,400]).to.include(status);\n  if (status === 400) {\n    pm.expect(missingFile).to.eql(true);\n  }\n});",
                  "if (![400].includes(status)) {",
                  "  const json = pm.response.json();",
                  "  pm.test('S3 Upload - ok true', () => {\n    pm.expect(json.ok).to.eql(true);\n  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST S3 Upload (Newman)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [
                    "{{s3_upload_file_path}}"
                  ]
                },
                {
                  "key": "key",
                  "value": "{{s3_object_key}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/s3/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "s3",
                "upload"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('S3 Upload (Newman) - status 200 ou 201', () => {\n  pm.expect([200,201]).to.include(pm.response.code);\n});",
                  "const json = pm.response.json();",
                  "pm.test('S3 Upload (Newman) - ok true', () => {\n  pm.expect(json.ok).to.eql(true);\n});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET S3 Download",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/s3/download?key={{s3_object_key}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "s3",
                "download"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{s3_object_key}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('S3 Download - status 200', () => {\n  pm.response.to.have.status(200);\n});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE S3 Object",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/s3/object?key={{s3_object_key}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "s3",
                "object"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{s3_object_key}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('S3 Delete - status 200', () => {\n  pm.response.to.have.status(200);\n});",
                  "const json = pm.response.json();",
                  "pm.test('S3 Delete - ok true', () => {\n  pm.expect(json.ok).to.eql(true);\n});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth Cleanup",
      "item": [
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout - status 200 ou 201', () => {\n  pm.expect([200,201]).to.include(pm.response.code);\n});",
                  "pm.environment.unset('auth_token');",
                  "pm.environment.unset('companyId');"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
