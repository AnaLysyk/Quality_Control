# Copy to .env and set your values

# Force Postgres persistence for the platform (avoids JSON/file mode in production).
AUTH_STORE=postgres

# Main platform database (plans, runs, docs, apps, management, and all non-automation modules)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Automation module database (preferred variables)
# AUTOMATION_DATABASE_URL=postgresql://user:password@host:5432/automation_db?sslmode=require
# AUTOMATION_PRISMA_DATABASE_URL=postgres://token@db.prisma.io:5432/postgres?sslmode=require
# AUTOMATION_POSTGRES_URL=postgresql://user:password@host:5432/automation_db?sslmode=require
# AUTOMATION_AUDIT_RETENTION_DAYS=30
# AUTOMATION_AUDIT_PRUNE_INTERVAL_SECONDS=600

# Legacy fallback supported by resolver (prefer automation-scoped vars above)
# PRISMA_DATABASE_URL=postgresql://user:password@host:5432/automation_db?sslmode=require
# POSTGRES_URL=postgresql://user:password@host:5432/automation_db?sslmode=require

# Backward-compatible Prisma aliases
# POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/dbname?sslmode=require
