# Local environment example
# Adjust values for your local Postgres instance.

DATABASE_URL="postgres://postgres:postgres@localhost:5432/inorbit2?schema=public"
JWT_SECRET="change-me"

# Auth token lifetimes (optional)
# - access token: short-lived JWT (used for auth on requests)
# - refresh token: long-lived opaque token stored hashed in Redis
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_SECONDS="2592000"

# Optional: pooler / unpooled URL (used by scripts/set-db-url-prod.js)
DATABASE_URL_UNPOOLED=""

# Optional integrations
QASE_BASE_URL="https://api.qase.io"
QASE_API_TOKEN=""
QASE_PROJECT_MAP=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: keep local auth store in memory only (non-persistent)
LOCAL_AUTH_IN_MEMORY="false"
