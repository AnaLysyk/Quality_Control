generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Defect {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String?
  status          String         @default("open")
  createdAt       DateTime       @default(now())
  companyId       String         @db.Uuid
  releaseManualId String?        @db.Uuid
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  releaseManual   ReleaseManual? @relation(fields: [releaseManualId], references: [id])
}

model ReleaseManual {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  createdAt   DateTime @default(now())
  status      String   @default("draft")
  companyId   String   @db.Uuid
  defects     Defect[]
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String        @unique
  password_hash String
  name          String        @default("")
  active        Boolean       @default(true)
  created_at    DateTime      @default(now())
  userCompanies UserCompany[]
}

model Company {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String          @unique
  defects        Defect[]
  releaseManuals ReleaseManual[]
  userCompanies  UserCompany[]
}

model UserCompany {
  user_id    String  @db.Uuid
  company_id String  @db.Uuid
  role       String  @default("user")
  company    Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, company_id])
}

model SupportRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String
  message    String
  status     String   @default("open")
  ip_address String?
  user_agent String?
  user_id    String?  @db.Uuid
  created_at DateTime @default(now())
}

model Release {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  title       String
  summary     String?
  runId       Int?
  project     String?
  app         String?
  qaseProject String?
  radis       String?
  order       String[]
  createdAt   DateTime @default(now())
  status      String   @default("draft")
  source      String?
  clientId    String?  @db.Uuid
  clientName  String?
}

model TestRun {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status     String
  created_at DateTime @default(now())
}
