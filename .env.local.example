# Local environment template (DO NOT commit real secrets)
# Copy to .env.local and fill values as needed.

# Auth (JWT)
JWT_SECRET=

# Database (OBRIGATORIO)
DATABASE_URL=
# Optional: non-pooling connection for admin tasks
DATABASE_URL_UNPOOLED=

# Qase
QASE_BASE_URL=https://api.qase.io
QASE_API_TOKEN=
QASE_TOKEN=
QASE_PROJECT_CODE=
QASE_PROJECT=
QASE_DEFAULT_PROJECT=
# Optional map: slug:CODE,slug2:CODE2 or JSON
QASE_PROJECT_MAP=
QASE_PROJECT_CODES=

# Playwright -> Qase reporting (optional)
QASE_RUN_ID=
QASE_DISABLED=

# Optional: Upstash Redis / Vercel KV (server-only)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: public Redis ping endpoint protection
REDIS_PING_SECRET=
