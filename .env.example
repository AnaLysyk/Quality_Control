# Copy to .env and set your values

# =========================================================
# BANCO OPERACIONAL DO SISTEMA
# Fonte do sistema/producao. Nao deve ser usado como RAG do Brain.
# =========================================================

DATABASE_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL=

# =========================================================
# BANCO RAG DO BRAIN
# Banco separado para memoria, grafo, auditoria e contexto do Brain.
# Variavel canonica: BRAIN_DATABASE_URL.
# BRAIN_RAG_DATABASE_URL ainda e aceito como alias legado, mas deve apontar para o mesmo banco.
# PRISMA_DATABASE_URL nao e usado como fallback do Brain/RAG.
# Deve ser diferente do DATABASE_URL fora de desenvolvimento local.
# =========================================================

BRAIN_DATABASE_URL=
# BRAIN_RAG_DATABASE_URL=

# Use true apenas em desenvolvimento local, se quiser reaproveitar o mesmo banco temporariamente.
BRAIN_ALLOW_PRIMARY_DATABASE=false

# =========================================================
# BRAIN COM BANCO + RAG + APIs GRATUITAS EM FALLBACK
# O banco/RAG sempre vem primeiro e eh a fonte principal.
# As APIs gratis so melhoram a conversa/resposta.
# Se nao houver chave/cota/resposta, usa template interno.
# =========================================================

BRAIN_ONLINE_MODEL_ENABLED=true
BRAIN_LOCAL_MODEL_ENABLED=false
BRAIN_FREE_ONLY=true
BRAIN_STRICT_FREE_MODELS=true

BRAIN_FREE_PROVIDER_ORDER=groq,gemini,openrouter
BRAIN_ONLINE_PROVIDER_TIMEOUT_MS=2500
BRAIN_MAX_OUTPUT_TOKENS=500

# =========================================================
# CHAVES DAS APIs GRATUITAS
# Preencha no .env local/producao. Nao versionar chaves reais.
# =========================================================

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile,qwen/qwen3-32b,openai/gpt-oss-20b,openai/gpt-oss-120b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
GEMINI_MODELS=gemini-3.5-flash-lite,gemini-3.5-flash,gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash-lite,gemini-1.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_MODELS=openrouter/free

# =========================================================
# LIMITES LOCAIS DE SEGURANCA
# Quando atingir um limite local, o Brain pula para o proximo provider.
# =========================================================

BRAIN_FREE_DAILY_REQUEST_LIMIT_GROQ=700
BRAIN_FREE_DAILY_TOKEN_LIMIT_GROQ=120000

BRAIN_FREE_DAILY_REQUEST_LIMIT_GEMINI=80
BRAIN_FREE_DAILY_TOKEN_LIMIT_GEMINI=60000

BRAIN_FREE_DAILY_REQUEST_LIMIT_OPENROUTER=40
BRAIN_FREE_DAILY_TOKEN_LIMIT_OPENROUTER=30000

# =========================================================
# IA LOCAL OPCIONAL
# Mantida desligada por padrao.
# =========================================================

# BRAIN_MODEL_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b

# BRAIN_MODEL_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL=local-model

# =========================================================
# BUSCA WEB OPCIONAL
# =========================================================

BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# =========================================================
# GITHUB (publicacao a partir do Postman e da IDE internos)
# Personal Access Token com escopo "repo" sobre AnaLysyk/Quality_Control.
# Gere em github.com/settings/tokens e cole apenas no .env/.env.local.
# =========================================================

GITHUB_TOKEN=
