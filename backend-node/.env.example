
PORT=3000
# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_or_service_key

# Database URLs
# Para desenvolvimento/local (direto):
DATABASE_URL="postgresql://postgres:<senha>@<host>.supabase.co:5432/postgres?sslmode=require"
# Para produção (pooler):
DATABASE_URL="postgres://postgres.<host>:<senha>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Prisma (produção, pooler):
POSTGRES_PRISMA_URL="postgres://postgres.<host>:<senha>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# S3
S3_ENDPOINT=https://glzoowczvjykxjxctjsq.storage.supabase.co/storage/v1/s3
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_BUCKET=Test
