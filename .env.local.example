# Local environment template (DO NOT commit real secrets)
# Copy to .env.local and fill values as needed.

# Auth mode
# If you are not using Supabase Auth anymore, set:
# SUPABASE_DISABLED=true
# and provide JWT_SECRET + users table in Postgres.
SUPABASE_DISABLED=
JWT_SECRET=

# Database (required for admin/users/clients persistence)
# This app uses @vercel/postgres in server-only repositories.
# Provide at least the pooled connection string:
POSTGRES_URL=
# Optional but recommended: direct/non-pooling connection string for admin tasks/migrations.
POSTGRES_URL_NON_POOLING=

# Compatibility aliases used by some scripts/docs.
# You can point these to the same values as POSTGRES_URL / POSTGRES_URL_NON_POOLING.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Base URL for Qase API. Optional; defaults to https://api.qase.io
QASE_BASE_URL=https://api.qase.io

# Qase authentication token (recommended). Used by server-only routes/services.
# If not set, Qase integration will gracefully show empty data in most views.
QASE_API_TOKEN=
# Alternative token name used in some places (optional)
QASE_TOKEN=

# Default project code (2-10 chars), e.g. SFQ
QASE_PROJECT_CODE=
# Alternative names used in the repo (optional)
QASE_PROJECT=
QASE_DEFAULT_PROJECT=

# Playwright -> Qase reporting (optional)
QASE_RUN_ID=
# Set to true to disable Qase reporting
QASE_DISABLED=

# Optional: Upstash Redis / Vercel KV (server-only)
# Only needed if you enable Redis/KV features in this app.
# Vercel KV-compatible names (recommended):
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional read-only token (not used by default)
KV_REST_API_READ_ONLY_TOKEN=

# Upstash native names (also supported by @upstash/redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: public Redis ping endpoint protection (/api/public/redis/ping)
# Provide a secret and call with ?secret=... or header x-redis-ping-secret
REDIS_PING_SECRET=

# Optional: Supabase (legacy; only if you still use Supabase-backed features)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL of this app (recommended for auth redirects)
# Example: https://painel-qa.example.com
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: RLS check script (legacy / Supabase local-only)
# Prefer using a JWT to avoid storing a password:
# ACCESS_TOKEN=
# Alternatively (less preferred):
# TEST_EMAIL=
# TEST_PASSWORD=
# VIEW_NAME=global_admins_view
# LIMIT=10

# Optional: Edge Function testing (legacy / Supabase local-only)
# CRON_SNAPSHOTS_API_URL=https://<project-ref>.supabase.co/functions/v1/cron-snapshots-api

# Backend (NestJS) base URL for Next.js proxy integration
# Example: http://127.0.0.1:8080/api
BACKEND_API_URL=
BACKEND_STRICT=
# ACCESS_TOKEN=

# Optional: override the deployed Edge Function URL used by /api/auth/reset-via-token (legacy)
# RESET_VIA_TOKEN_FN_URL=https://<project-ref>.supabase.co/functions/v1/reset-via-token
