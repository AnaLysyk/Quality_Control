{
  "name": "quality-control",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:logs": "bash support/functions/infraestrutura/desenvolvimento/limpar-logs.sh || powershell -ExecutionPolicy Bypass -File support/functions/infraestrutura/desenvolvimento/limpar-logs.ps1",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "build:clean": "npm run clean && npm run build",
    "dev:clean": "node support/functions/infraestrutura/desenvolvimento/iniciar-desenvolvimento-limpo.js",
    "dev": "node support/functions/infraestrutura/desenvolvimento/iniciar-servidor-desenvolvimento.js --webpack",
    "dev:webpack": "node support/functions/infraestrutura/desenvolvimento/iniciar-servidor-desenvolvimento.js --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:ci": "cross-env NEXT_DISABLE_FONT_DOWNLOAD=1 next dev --webpack -p 3100 -H 127.0.0.1",
    "dev:ci:clean": "node support/functions/infraestrutura/compilacao/limpar-cache-next.js && npm run dev:ci",
    "build": "node support/functions/infraestrutura/compilacao/preparar-banco-para-compilacao.js && next build",
    "start": "next start",
    "lint": "eslint --max-warnings 9999",
    "typecheck": "node support/functions/infraestrutura/compilacao/limpar-cache-next.js && tsc --noEmit",
    "guard:permissions-catalog": "jest --config jest.config.ts --runInBand testes/api/geral/system-map.test.ts",
    "test:permissions": "jest --config jest.config.ts --runInBand testes/api/geral/system-map.test.ts testes/api/permissoes testes/bd/sessao/session.store.test.ts testes/api/usuarios/usuarios-access.test.ts testes/api/usuarios/user-scope-policy.test.ts testes/api/unitarios/permissionMatrix.test.ts testes/api/unitarios/userScopePolicy.test.ts testes/api/unitarios/validateCompanyAccess.test.ts testes/api/unitarios/rbacTickets.test.ts testes/api/unitarios/supportAccess.test.ts",
    "email:preview:access-requests": "tsx support/functions/api/email/gerar-preview-email-solicitacao-acesso.ts",
    "test": "jest --config jest.config.ts --passWithNoTests --testMatch \"**/testes/**/*.test.ts?(x)\"",
    "test:coverage": "jest --config jest.config.ts --coverage --coverageReporters=lcov --coverageReporters=text --passWithNoTests --testMatch \"**/testes/**/*.test.ts?(x)\"",
    "test:biometrics": "jest --config jest.config.ts --runInBand testes/api/geral/biometrics-fingerprint-processor.test.ts",
    "test:e2e": "cross-env E2E_USE_JSON=1 playwright test",
    "test:e2e:projects": "cross-env E2E_USE_JSON=1 playwright test --list",
    "test:e2e:headed": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PLAYWRIGHT_SCREENSHOT=on playwright test --headed",
    "test:e2e:ui": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PLAYWRIGHT_SCREENSHOT=on playwright test --ui",
    "test:e2e:debug": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on PWDEBUG=1 playwright test --debug",
    "test:e2e:edge": "cross-env E2E_USE_JSON=1 PLAYWRIGHT_HEADED=1 PLAYWRIGHT_CHANNEL=msedge PLAYWRIGHT_TRACE=on PLAYWRIGHT_VIDEO=on playwright test --headed",
    "test:e2e:trace": "playwright show-trace",
    "backfill:company-integrations": "tsx support/functions/banco-de-dados/migracoes/integracoes/preencher-integracoes-existentes.ts",
    "test:e2e:smoke": "cross-env E2E_USE_JSON=1 playwright test --project=quality-smoke",
    "test:e2e:access": "cross-env E2E_USE_JSON=1 playwright test --project=quality-access",
    "test:solicitar-acesso:ui": "cross-env E2E_USE_JSON=1 playwright test testes/ui/login/solicitar-acesso --project=chromium",
    "test:solicitar-acesso:api": "cross-env E2E_USE_JSON=1 playwright test testes/api/solicitar-acesso --project=chromium",
    "test:solicitar-acesso:bd": "cross-env E2E_USE_JSON=1 playwright test testes/bd/solicitar-acesso --project=chromium",
    "test:solicitar-acesso:acessibilidade": "cross-env E2E_USE_JSON=1 playwright test testes/ui/login/solicitar-acesso/formulario-publico/acessibilidade testes/ui/login/solicitar-acesso/gestao-solicitacoes/acessibilidade --project=chromium",
    "test:esqueci-senha:ui": "cross-env E2E_USE_JSON=1 playwright test testes/ui/login/esqueci-senha --project=chromium",
    "test:acessibilidade": "cross-env E2E_USE_JSON=1 playwright test **/*.acessibilidade.ui.spec.ts --project=chromium",
    "test:e2e:cases": "cross-env E2E_USE_JSON=1 playwright test --project=quality-test-cases",
    "test:e2e:profile-cycle": "cross-env E2E_USE_JSON=1 playwright test testes/ui/repositorio-casos/perfis/case-repository-profile-cycle.spec.ts --project=chromium",
    "test:e2e:automation-link": "cross-env E2E_USE_JSON=1 playwright test testes/ui/casos-de-teste/test-case-automation-link.spec.ts --project=chromium",
    "test:e2e:runs": "cross-env E2E_USE_JSON=1 playwright test --project=quality-runs",
    "test:e2e:automation": "cross-env E2E_USE_JSON=1 playwright test --project=quality-automation",
    "test:e2e:dashboards": "cross-env E2E_USE_JSON=1 playwright test --project=quality-dashboards",
    "test:e2e:ai": "cross-env E2E_USE_JSON=1 playwright test --project=quality-ai",
    "test:e2e:visual": "cross-env E2E_USE_JSON=1 playwright test --project=quality-ui",
    "test:e2e:prod": "playwright test -c playwright.prod.config.ts --headed",
    "test:api": "node support/functions/api/newman/executar-colecao-postman.mjs",
    "biometrics:attach": "tsx support/functions/api/biometria/executar-anexo-biometrico-local.ts",
    "env:check": "tsx support/functions/infraestrutura/ambiente/verificar-variaveis-ambiente.ts",
    "dev:watch": "powershell -ExecutionPolicy Bypass -File support/functions/infraestrutura/desenvolvimento/acompanhar-servidor-desenvolvimento.ps1",
    "dev:daemon": "node support/functions/infraestrutura/desenvolvimento/iniciar-servidor-segundo-plano.js",
    "dev:stop": "node support/functions/infraestrutura/desenvolvimento/parar-servidor-desenvolvimento.js",
    "create-admin": "npx tsx support/functions/banco-de-dados/usuarios/criar-administrador.ts",
    "create-ana-admin": "npx tsx support/functions/banco-de-dados/usuarios/criar-administrador-ana.ts",
    "seed:ana-admin": "npx tsx support/functions/banco-de-dados/usuarios/criar-administrador-ana.ts",
    "seed:mttr-goal": "tsx support/functions/banco-de-dados/geradores-dados/criar-dados-mttr-meta.ts",
    "seed:run-defects": "tsx support/functions/banco-de-dados/geradores-dados/criar-execucao-com-defeitos.ts",
    "seed:risk": "tsx support/functions/banco-de-dados/geradores-dados/criar-dados-risco.ts",
    "seed:runs-search-quality-sla": "tsx support/functions/banco-de-dados/geradores-dados/criar-execucoes-busca-qualidade-sla.ts",
    "seed:quality-alert": "tsx support/functions/banco-de-dados/geradores-dados/criar-dados-base.ts",
    "seed:dev-access": "prisma generate && tsx support/functions/banco-de-dados/geradores-dados/criar-acesso-desenvolvimento.ts",
    "seed:demo": "npx tsx support/functions/banco-de-dados/geradores-dados/criar-dados-demonstracao.ts",
    "seed:all": "npm run seed:ana-admin && npm run seed:quality-alert && npm run seed:demo",
    "postinstall": "node support/functions/infraestrutura/manutencao/corrigir-pacote-server-only.js",
    "db:check": "node support/functions/api/diagnosticos/testar-conexao-banco.js",
    "brain:sync": "tsx support/functions/banco-de-dados/brain/sincronizar-brain.ts",
    "brain:maintenance": "tsx support/functions/banco-de-dados/brain/executar-manutencao-brain.ts",
    "brain:reindex": "tsx support/functions/banco-de-dados/brain/sincronizar-brain.ts",
    "brain:test": "jest --config jest.config.ts --runInBand testes/bd/brain/brain.test.ts",
    "test:brain:contracts": "jest --config jest.config.ts --runInBand testes/api/geral/brain-ingest-contract.test.ts testes/api/geral/brain-commands-confirmation.test.ts",
    "docs:check-api": "tsx support/functions/documentacao/verificar-cobertura-openapi.ts",
    "docs:sync-quality-control": "tsx support/functions/documentacao/sincronizar-documentacao-quality-control.ts",
    "docs:capture-screens": "cross-env PLAYWRIGHT_USE_EXISTING=1 playwright test testes/ui/documentacao/documentacao-quality-control.spec.ts --project=chromium",
    "sonar:scan": "sonar-scanner",
    "sonar:scan:debug": "sonar-scanner -X",
    "sonar:issues": "node support/functions/infraestrutura/qualidade/baixar-problemas-sonar.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.61",
    "@aws-sdk/client-s3": "^3.975.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/redis": "^1.36.1",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.175",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "next": "16.2.9",
    "nodemailer": "^8.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-is": "^19.1.1",
    "recharts": "^3.5.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^6.4.14",
    "@types/papaparse": "^5.5.1",
    "@types/react": "^19",
    "@types/supertest": "^6.0.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-react-hooks": "7.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
