# Copy to .env and set your values

# Brain IA local gratuita
# OpÃ§Ã£o 1: Ollama
# BRAIN_MODEL_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b

# OpÃ§Ã£o 2: LM Studio
# BRAIN_MODEL_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL=local-model

# Web opcional
# BRAVE_SEARCH_API_KEY=
# TAVILY_API_KEY=


# Brain performance
# Por padrÃ£o o Brain responde rÃ¡pido usando banco/RAG/template.
# Ative IA local somente se o Ollama/LM Studio estiver rodando.
# BRAIN_LOCAL_MODEL_ENABLED=true

# Brain IA online com providers grátis/fallback
BRAIN_ONLINE_MODEL_ENABLED=true
BRAIN_LOCAL_MODEL_ENABLED=false
BRAIN_FREE_PROVIDER_ORDER=groq,gemini,openrouter
BRAIN_ONLINE_PROVIDER_TIMEOUT_MS=6000

# Groq Free Plan
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini API Free Tier
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# OpenRouter Free Router
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Brain IA grátis/fallback
BRAIN_ONLINE_MODEL_ENABLED=true
BRAIN_LOCAL_MODEL_ENABLED=false
BRAIN_FREE_ONLY=true
BRAIN_STRICT_FREE_MODELS=true
BRAIN_FREE_PROVIDER_ORDER=groq,gemini,openrouter
BRAIN_ONLINE_PROVIDER_TIMEOUT_MS=4500
BRAIN_MAX_OUTPUT_TOKENS=700

BRAIN_FREE_DAILY_REQUEST_LIMIT_GROQ=700
BRAIN_FREE_DAILY_TOKEN_LIMIT_GROQ=120000
BRAIN_FREE_DAILY_REQUEST_LIMIT_GEMINI=80
BRAIN_FREE_DAILY_TOKEN_LIMIT_GEMINI=60000
BRAIN_FREE_DAILY_REQUEST_LIMIT_OPENROUTER=40
BRAIN_FREE_DAILY_TOKEN_LIMIT_OPENROUTER=30000

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
