# Local environment example (internal QA tool)
# The app runs without DB by default (local JSON stores). Postgres/Prisma is optional/legacy.

# Recommended: enable JWT cookie auth (otherwise it falls back to session_id + Redis/memory).
JWT_SECRET="change-me"

# Optional/legacy: enable Prisma/DB-backed features/scripts.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/quality_control?schema=public"

# Optional: pooler / unpooled URL (used by scripts/set-db-url-prod.js)
DATABASE_URL_UNPOOLED=""

# Optional: local auth store in memory only (no writes to data/local-auth-store.json)
LOCAL_AUTH_IN_MEMORY="false"

# Optional: manual releases store in memory only (no writes to data/releases-manual*.json)
MANUAL_RELEASES_IN_MEMORY="false"

# Optional: Qase integration (global token + per-company tokens)
QASE_BASE_URL="https://api.qase.io"
QASE_API_TOKEN=""
# Example per company (slug is normalized to uppercase with underscores):
# QASE_API_TOKEN_GRIAULE=""
QASE_PROJECT_MAP=""

# Optional: Upstash Redis (if not set, falls back to in-memory; not persistent)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
