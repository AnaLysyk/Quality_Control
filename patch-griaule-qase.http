// Exemplo de requisição PATCH para atualizar a empresa Griaule com integração Qase
// Salve este arquivo como patch-griaule-qase.http e execute com REST Client (VSCode) ou via curl

PATCH http://localhost:3000/api/clients/griaule
Content-Type: application/json
Authorization: Bearer SEU_TOKEN_ADMIN_AQUI

{
  "qase_token": "423a5f95cf6418b924857f9fc04d2a34a5c533c922132407f09ffd79874bec79",
  "qase_project_codes": [
    "MIR",
    "TRUST",
    "SMART"
  ]
}

// Substitua SEU_TOKEN_ADMIN_AQUI por um token de admin válido.
// Execute com REST Client (VSCode) ou curl:
// curl -X PATCH http://localhost:3000/api/clients/griaule -H "Content-Type: application/json" -H "Authorization: Bearer SEU_TOKEN_ADMIN_AQUI" -d '{"qase_token":"423a5f95cf6418b924857f9fc04d2a34a5c533c922132407f09ffd79874bec79","qase_project_codes":["MIR","TRUST","SMART"]}'
