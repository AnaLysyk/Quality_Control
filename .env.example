# Copy to .env and set your values

# =========================================================
# BRAIN SEM MODELO EXTERNO
# Funciona com banco + RAG + templates internos.
# Nao tenta Groq, Gemini, OpenRouter nem Ollama por padrao.
# =========================================================

BRAIN_ONLINE_MODEL_ENABLED=false
BRAIN_LOCAL_MODEL_ENABLED=false
BRAIN_FREE_ONLY=true
BRAIN_STRICT_FREE_MODELS=true

BRAIN_FREE_PROVIDER_ORDER=groq,gemini,openrouter
BRAIN_ONLINE_PROVIDER_TIMEOUT_MS=2500
BRAIN_MAX_OUTPUT_TOKENS=500

# =========================================================
# LIMITES LOCAIS
# Pode deixar, mesmo sem chaves configuradas.
# =========================================================

BRAIN_FREE_DAILY_REQUEST_LIMIT_GROQ=700
BRAIN_FREE_DAILY_TOKEN_LIMIT_GROQ=120000

BRAIN_FREE_DAILY_REQUEST_LIMIT_GEMINI=80
BRAIN_FREE_DAILY_TOKEN_LIMIT_GEMINI=60000

BRAIN_FREE_DAILY_REQUEST_LIMIT_OPENROUTER=40
BRAIN_FREE_DAILY_TOKEN_LIMIT_OPENROUTER=30000

# =========================================================
# IA LOCAL OPCIONAL
# Mantida desligada por padrao. Ative apenas se existir servidor local.
# =========================================================

# BRAIN_MODEL_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1:8b

# BRAIN_MODEL_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_MODEL=local-model

# =========================================================
# BUSCA WEB OPCIONAL
# Mantida vazia por padrao.
# =========================================================

BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
